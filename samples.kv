ScreenManager:
    TradePointsScreen:
    TradePointDetailScreen:
    AddPointScreen:
    ReportScreen:

<TradePointsScreen>:
    name: 'points'
    BoxLayout:
        orientation: 'vertical'
        BoxLayout:
            size_hint_y: 0.1
            Spinner:
                id: client_spinner
                text: ''
                values: [''] + [c[1] for c in app.get_all_clients_simple()]
                on_text: root.apply_filters()
            TextInput:
                id: address_input
                hint_text: 'Часть адреса'
                on_text: root.apply_filters()
            Button:
                text: 'Сброс'
                on_press: root.reset_filters()
        RecycleView:
            id: points_list
            viewclass: 'Button'
            data: []
            RecycleBoxLayout:
                default_size: None, dp(50)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
        BoxLayout:
            size_hint_y: 0.1
            Button:
                text: 'Добавить точку'
                on_press: root.open_add_point()
            Button:
                text: 'Отчёты'
                on_press: root.manager.current = 'reports'

<TradePointDetailScreen>:
    name: 'detail'
    BoxLayout:
        orientation: 'vertical'
        BoxLayout:
            size_hint_y: 0.15
            Label:
                id: point_code
                text: 'Код'
                bold: True
            Label:
                id: client
                text: 'Клиент'
            Label:
                id: address
                text: 'Адрес'
        BoxLayout:
            size_hint_y: 0.1
            Button:
                text: 'Назад'
                on_press: root.go_back()
            Button:
                text: '+ Коллекция'
                on_press: root.add_collection_dialog()
        RecycleView:
            id: samples_list
            viewclass: 'SampleItem'
            data: []
            RecycleBoxLayout:
                default_size: None, dp(45)
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: 'vertical'
        BoxLayout:
            size_hint_y: 0.15
            Button:
                text: 'Все → Есть'
                on_press: root.set_all_status('Есть')
            Button:
                text: 'Все → Нет'
                on_press: root.set_all_status('нет')
            Button:
                text: 'Все → Обещан'
                on_press: root.set_all_status('нет нужно')
            Button:
                text: 'Все → Не нужен'
                on_press: root.set_all_status('ненужно')
            Button:
                text: 'Все → Возвращен'
                on_press: root.set_all_status('возвращен')

<SampleItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(40)
    Label:
        text: root.collection
        size_hint_x: 0.6
    Spinner:
        size_hint_x: 0.4
        text: root.status
        values: ['Есть', 'нет', 'нет нужно', 'ненужно', 'возвращен']
        on_text: root.change_status(self.text)

<AddPointScreen>:
    name: 'add_point'
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(10)
        Label:
            text: 'Добавление торговой точки'
            font_size: '20sp'
        TextInput:
            id: code_input
            hint_text: 'Код точки (уникальный)'
        Spinner:
            id: client_spinner
            text: 'Без клиента'
            values: ['Без клиента'] + [c[1] for c in app.get_all_clients_simple()]
        TextInput:
            id: address_input
            hint_text: 'Адрес'
        TextInput:
            id: comment_input
            hint_text: 'Комментарий'
        BoxLayout:
            size_hint_y: 0.2
            Button:
                text: 'Сохранить'
                on_press: root.save_point()
            Button:
                text: 'Отмена'
                on_press: root.manager.current = 'points'

<ReportScreen>:
    name: 'reports'
    BoxLayout:
        orientation: 'vertical'
        BoxLayout:
            size_hint_y: 0.1
            Button:
                text: 'Назад'
                on_press: root.go_back()
            Button:
                text: 'Что нужно привезти'
                on_press: root.show_needed_report()
            Button:
                text: 'Кол-во по точкам'
                on_press: root.show_collection_report()
        ScrollView:
            Label:
                id: report_label
                text: 'Выберите отчёт'
                text_size: self.width, None
                size_hint_y: None
                height: self.texture_size[1]